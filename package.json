{
  "name": "portfolio-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "check-types": "tsc --pretty --noEmit",
    "check-format": "prettier --check .",
    "check-lint": "pnpm eslint src",
    "format": "prettier . -w",
    "test-all": "pnpm run format && pnpm run check-types && pnpm run check-lint && pnpm run check-format && pnpm run build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "install": "^0.13.0",
    "lucide-react": "^0.394.0",
    "next": "14.2.3",
    "pnpm": "^9.3.0",
    "react": "^18",
    "react-dom": "^18",
    "react-fast-marquee": "^1.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "eslint-plugin-react": "^7.34.1",
    "globals": "^15.2.0",
    "husky": "^8.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "typescript-eslint": "^7.9.0"
  }
}
